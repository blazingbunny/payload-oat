# Payload
DATABASE_URI=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
PAYLOAD_SECRET=your-secret-here
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Vercel Blob (optional — local dev can skip)
BLOB_READ_WRITE_TOKEN=

# First tenant domain (for media URLs)
NEXT_PUBLIC_FIRST_TENANT_DOMAIN=adriandelrosario.com

# Go oat server
# Connection string for the read-only oat_reader Postgres user
SUPABASE_DSN=postgresql://oat_reader:[password]@db.[project].supabase.co:5432/postgres
PORT=8080

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
